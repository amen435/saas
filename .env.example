# Local dev (Vite proxies /api → backend on localhost:5000):
# VITE_API_URL=/api
#
# Production (Vercel) — set explicitly (recommended):
# VITE_API_URL=https://saas-backend-oddg.onrender.com/api
#
# Never set VITE_API_URL to http://localhost:5000 for Production/Preview (breaks every user’s browser).
# `vite build` strips loopback from VITE_* in production mode; still delete bad values on Vercel.
VITE_API_URL=/api
